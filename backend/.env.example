# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Anon Key = publishable key (safe for frontend, respects RLS)
SUPABASE_ANON_KEY=your-anon-key
# Service Role Key = secret admin key (bypasses RLS, backend only — NOT the publishable key)
# Find it: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Supabase PostgreSQL direct connection) ───
# Must use postgresql+asyncpg:// for async SQLAlchemy
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Security ──────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
CREDENTIAL_ENCRYPTION_KEY=change-me-32-byte-base64-key

# ─── AI / LLM ─────────────────────────────────────────
# At least one of the two keys below is required.
# Both is recommended — Claude is primary, Gemini is automatic fallback
# (activates on rate-limit, quota exhaustion, or service outage).
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ─── TinyFish Browser Automation ──────────────────────
TINYFISH_API_KEY=tf-...
# Base URL from: https://agent.tinyfish.ai/v1/automation/run-sse
TINYFISH_BASE_URL=https://agent.tinyfish.ai/v1

# ─── App Settings ─────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CHECKPOINT_INTERVAL_SECONDS=90
AGENT_TIMEOUT_SECONDS=14400
